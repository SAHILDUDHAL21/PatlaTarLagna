# Copy this file to .env in the patlatrlagna/ directory and fill values (do NOT commit real secrets)
# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=patlatarlagna
DB_USER=root
DB_PASSWORD=

# Mail (SMTP)
MAIL_HOST=localhost
MAIL_PORT=2525
MAIL_USER=user
MAIL_PASSWORD=pass

# Other defaults
UPLOAD_DIR=uploads

# JWT (optional override)
#JWT_SECRET=...
#JWT_EXPIRATION=86400000
